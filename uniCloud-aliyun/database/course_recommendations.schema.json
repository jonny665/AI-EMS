{
  "bsonType": "object",
  "required": [
    "student_id",
    "semester_id",
    "recommended_course_id",
    "score",
    "reason",
    "evidence",
    "status",
    "created_at",
    "updated_at"
  ],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "course_recommendations primary key"
    },
    "student_id": {
      "bsonType": "string",
      "description": "References students._id"
    },
    "semester_id": {
      "bsonType": "string",
      "description": "References semesters._id"
    },
    "recommended_course_id": {
      "bsonType": "string",
      "description": "References courses._id"
    },
    "recommended_offering_id": {
      "bsonType": "string",
      "description": "References course_offerings._id"
    },
    "path_name": {
      "bsonType": "string",
      "description": "Example: Data Analysis or Software Engineering."
    },
    "score": {
      "bsonType": "number"
    },
    "reason": {
      "bsonType": "string"
    },
    "evidence": {
      "bsonType": "object",
      "description": "Grades, completed courses, interest tags and evaluation scores used."
    },
    "status": {
      "bsonType": "string",
      "enum": [
        "new",
        "viewed",
        "accepted",
        "dismissed"
      ],
      "defaultValue": "new"
    },
    "created_at": {
      "bsonType": "number"
    },
    "updated_at": {
      "bsonType": "number"
    }
  }
}

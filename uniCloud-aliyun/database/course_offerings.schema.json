{
  "bsonType": "object",
  "required": [
    "course_id",
    "semester_id",
    "section_no",
    "teacher_ids",
    "capacity",
    "enrolled_count",
    "selection_status",
    "created_at",
    "updated_at"
  ],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "course_offerings primary key"
    },
    "course_id": {
      "bsonType": "string",
      "description": "References courses._id"
    },
    "semester_id": {
      "bsonType": "string",
      "description": "References semesters._id"
    },
    "section_no": {
      "bsonType": "string"
    },
    "teacher_ids": {
      "bsonType": "array",
      "description": "References teachers._id"
    },
    "capacity": {
      "bsonType": "int"
    },
    "enrolled_count": {
      "bsonType": "int",
      "defaultValue": 0
    },
    "selection_status": {
      "bsonType": "string",
      "enum": [
        "not_started",
        "open",
        "closed",
        "cancelled"
      ],
      "defaultValue": "not_started"
    },
    "syllabus_url": {
      "bsonType": "string"
    },
    "created_at": {
      "bsonType": "number"
    },
    "updated_at": {
      "bsonType": "number"
    }
  }
}

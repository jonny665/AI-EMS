{
  "bsonType": "object",
  "required": [
    "conversation_id",
    "role",
    "content",
    "fallback_used",
    "created_at"
  ],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "ai_messages primary key"
    },
    "conversation_id": {
      "bsonType": "string",
      "description": "References ai_conversations._id."
    },
    "role": {
      "bsonType": "string",
      "enum": ["user", "assistant", "system"]
    },
    "content": {
      "bsonType": "string"
    },
    "model": {
      "bsonType": "string",
      "description": "Current PoC uses local-keyword-kb."
    },
    "citations": {
      "bsonType": "array",
      "description": "Referenced knowledge_base or knowledge_chunk ids and snippets."
    },
    "fallback_used": {
      "bsonType": "bool",
      "defaultValue": false
    },
    "latency_ms": {
      "bsonType": "int"
    },
    "created_at": {
      "bsonType": "number",
      "description": "Used by get-ai-history and ask-assistant to remove messages older than 60 days."
    }
  },
  "indexes": [
    {
      "name": "conversation_created_idx",
      "key": {
        "conversation_id": 1,
        "created_at": 1
      },
      "unique": false
    },
    {
      "name": "retention_created_idx",
      "key": {
        "created_at": 1
      },
      "unique": false
    }
  ]
}

{
  "bsonType": "object",
  "required": [
    "student_id",
    "course_offering_id",
    "leave_date",
    "reason_type",
    "reason_detail",
    "start_at",
    "end_at",
    "status",
    "created_at",
    "updated_at"
  ],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "leave_requests primary key"
    },
    "student_id": {
      "bsonType": "string",
      "description": "References students._id"
    },
    "course_offering_id": {
      "bsonType": "string",
      "description": "References course_offerings._id"
    },
    "leave_date": {
      "bsonType": "string",
      "description": "ISO date string for the requested leave day."
    },
    "reason_type": {
      "bsonType": "string",
      "enum": [
        "sick",
        "personal",
        "official",
        "other"
      ]
    },
    "reason_detail": {
      "bsonType": "string"
    },
    "start_at": {
      "bsonType": "number"
    },
    "end_at": {
      "bsonType": "number"
    },
    "attachment_urls": {
      "bsonType": "array"
    },
    "status": {
      "bsonType": "string",
      "enum": [
        "pending",
        "approved",
        "rejected",
        "cancel_requested",
        "cancelled"
      ],
      "defaultValue": "pending"
    },
    "reviewer_user_id": {
      "bsonType": "string",
      "description": "References users._id"
    },
    "review_comment": {
      "bsonType": "string"
    },
    "reviewed_at": {
      "bsonType": "number"
    },
    "created_at": {
      "bsonType": "number"
    },
    "updated_at": {
      "bsonType": "number"
    }
  },
  "indexes": [
    {
      "name": "student_status_created_idx",
      "key": {
        "student_id": 1,
        "status": 1,
        "created_at": -1
      },
      "unique": false
    },
    {
      "name": "course_status_date_idx",
      "key": {
        "course_offering_id": 1,
        "status": 1,
        "leave_date": -1
      },
      "unique": false
    }
  ]
}

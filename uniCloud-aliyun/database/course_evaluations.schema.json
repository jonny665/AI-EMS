{
  "bsonType": "object",
  "required": [
    "course_id",
    "course_offering_id",
    "teacher_ids",
    "token_hash",
    "scores",
    "status",
    "submitted_at",
    "created_at",
    "updated_at"
  ],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "course_evaluations primary key"
    },
    "course_id": {
      "bsonType": "string",
      "description": "References courses._id"
    },
    "course_offering_id": {
      "bsonType": "string",
      "description": "References course_offerings._id"
    },
    "teacher_ids": {
      "bsonType": "array",
      "description": "References teachers._id"
    },
    "token_hash": {
      "bsonType": "string",
      "description": "Anonymous token hash, unique for one submission."
    },
    "scores": {
      "bsonType": "object",
      "description": "content, teaching_method, difficulty, workload, achievement, overall; usually 1-5."
    },
    "difficulty_score": {
      "bsonType": "number"
    },
    "workload_score": {
      "bsonType": "number"
    },
    "feedback_text": {
      "bsonType": "string"
    },
    "status": {
      "bsonType": "string",
      "enum": ["submitted", "indexed", "hidden"],
      "defaultValue": "submitted"
    },
    "submitted_at": {
      "bsonType": "number"
    },
    "created_at": {
      "bsonType": "number"
    },
    "updated_at": {
      "bsonType": "number"
    }
  },
  "indexes": [
    {
      "name": "token_hash_unique",
      "key": {
        "token_hash": 1
      },
      "unique": true
    },
    {
      "name": "course_status_submitted_idx",
      "key": {
        "course_offering_id": 1,
        "status": 1,
        "submitted_at": -1
      },
      "unique": false
    },
    {
      "name": "teacher_status_idx",
      "key": {
        "teacher_ids": 1,
        "status": 1
      },
      "unique": false
    }
  ]
}

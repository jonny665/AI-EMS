{
  "bsonType": "object",
  "required": [
    "enrollment_id",
    "student_id",
    "course_offering_id",
    "credits_earned",
    "status",
    "created_at",
    "updated_at"
  ],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "grades primary key"
    },
    "enrollment_id": {
      "bsonType": "string",
      "description": "References enrollments._id"
    },
    "student_id": {
      "bsonType": "string",
      "description": "References students._id"
    },
    "course_offering_id": {
      "bsonType": "string",
      "description": "References course_offerings._id"
    },
    "score": {
      "bsonType": "number"
    },
    "grade_letter": {
      "bsonType": "string"
    },
    "gpa_point": {
      "bsonType": "number"
    },
    "credits_earned": {
      "bsonType": "number",
      "defaultValue": 0
    },
    "percentile": {
      "bsonType": "number"
    },
    "status": {
      "bsonType": "string",
      "enum": [
        "draft",
        "published",
        "appealed",
        "locked"
      ],
      "defaultValue": "draft"
    },
    "published_at": {
      "bsonType": "number"
    },
    "created_at": {
      "bsonType": "number"
    },
    "updated_at": {
      "bsonType": "number"
    }
  }
}

{
  "bsonType": "object",
  "required": [
    "code",
    "name",
    "permissions",
    "created_at",
    "updated_at"
  ],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "roles primary key"
    },
    "code": {
      "bsonType": "string",
      "enum": [
        "admin",
        "academic_staff",
        "counselor",
        "teacher",
        "student",
        "guardian"
      ],
      "description": "Stable role code."
    },
    "name": {
      "bsonType": "string",
      "description": "Display name."
    },
    "permissions": {
      "bsonType": "array",
      "description": "Permission keys, for example attendance.read.class or profile.review.approve."
    },
    "created_at": {
      "bsonType": "number"
    },
    "updated_at": {
      "bsonType": "number"
    }
  }
}

{
  "bsonType": "object",
  "required": ["course_offering_id", "weekday", "start_time", "end_time", "session_date", "status", "created_at", "updated_at"],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": { "description": "class_sessions primary key" },
    "course_offering_id": { "bsonType": "string", "description": "References course_offerings._id" },
    "classroom_id": { "bsonType": "string", "description": "References classrooms._id" },
    "weekday": { "bsonType": "int", "description": "1-7, Monday as 1." },
    "start_time": { "bsonType": "string", "description": "HH:mm." },
    "end_time": { "bsonType": "string", "description": "HH:mm." },
    "week_start": { "bsonType": "int" },
    "week_end": { "bsonType": "int" },
    "sequence_no": { "bsonType": "int" },
    "session_date": { "bsonType": "string", "description": "ISO date for generated concrete sessions." },
    "session_start_at": { "bsonType": "number" },
    "session_end_at": { "bsonType": "number" },
    "status": { "bsonType": "string", "enum": ["scheduled", "cancelled", "makeup"], "defaultValue": "scheduled" },
    "created_at": { "bsonType": "number" },
    "updated_at": { "bsonType": "number" }
  },
  "indexes": [
    {
      "name": "offering_date_unique",
      "key": { "course_offering_id": 1, "session_date": 1 },
      "unique": true
    }
  ]
}

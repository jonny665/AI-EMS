{
  "bsonType": "object",
  "required": [
    "user_id",
    "token_hash",
    "expires_at",
    "status",
    "created_at",
    "updated_at"
  ],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "password_reset_tokens primary key"
    },
    "user_id": {
      "bsonType": "string",
      "description": "References users._id"
    },
    "token_hash": {
      "bsonType": "string",
      "description": "One-way hash of the reset token. Never store the raw reset token."
    },
    "purpose": {
      "bsonType": "string",
      "enum": [
        "password_reset",
        "initial_setup",
        "admin_reset"
      ],
      "defaultValue": "password_reset"
    },
    "expires_at": {
      "bsonType": "number"
    },
    "used_at": {
      "bsonType": "number"
    },
    "status": {
      "bsonType": "string",
      "enum": [
        "active",
        "used",
        "expired",
        "revoked"
      ],
      "defaultValue": "active"
    },
    "request_ip": {
      "bsonType": "string"
    },
    "created_at": {
      "bsonType": "number"
    },
    "updated_at": {
      "bsonType": "number"
    }
  }
}

{
  "bsonType": "object",
  "required": [
    "student_id",
    "course_offering_id",
    "status",
    "selected_at",
    "created_at",
    "updated_at"
  ],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "enrollments primary key"
    },
    "student_id": {
      "bsonType": "string",
      "description": "References students._id"
    },
    "course_offering_id": {
      "bsonType": "string",
      "description": "References course_offerings._id"
    },
    "status": {
      "bsonType": "string",
      "enum": ["selected", "enrolled", "waitlisted", "dropped", "completed", "failed"],
      "defaultValue": "selected"
    },
    "selected_teacher_id": {
      "bsonType": "string",
      "description": "Teacher chosen by the student for this cohort offering. References teachers._id."
    },
    "selected_teacher_user_id": {
      "bsonType": "string",
      "description": "Cached teachers.user_id for material and attendance ownership filtering."
    },
    "selected_teacher_name": {
      "bsonType": "string"
    },
    "teacher_selected_at": {
      "bsonType": "number"
    },
    "selected_at": {
      "bsonType": "number"
    },
    "dropped_at": {
      "bsonType": "number"
    },
    "created_at": {
      "bsonType": "number"
    },
    "updated_at": {
      "bsonType": "number"
    }
  },
  "indexes": [
    {
      "name": "student_offering_unique",
      "key": {
        "student_id": 1,
        "course_offering_id": 1
      },
      "unique": true
    },
    {
      "name": "offering_status_idx",
      "key": {
        "course_offering_id": 1,
        "status": 1
      },
      "unique": false
    },
    {
      "name": "teacher_offering_idx",
      "key": {
        "selected_teacher_id": 1,
        "course_offering_id": 1
      },
      "unique": false
    }
  ]
}

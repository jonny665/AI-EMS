{
  "bsonType": "object",
  "required": [
    "user_id",
    "scenario",
    "message_count",
    "status",
    "created_at",
    "updated_at"
  ],
  "permission": {
    "read": false,
    "create": false,
    "update": false,
    "delete": false
  },
  "properties": {
    "_id": {
      "description": "ai_conversations primary key"
    },
    "user_id": {
      "bsonType": "string",
      "description": "References users._id; this binds each assistant history to one person."
    },
    "title": {
      "bsonType": "string"
    },
    "scenario": {
      "bsonType": "string",
      "enum": ["policy_qa", "course_selection", "schedule_query", "exam_query", "graduation_check", "other"],
      "defaultValue": "other"
    },
    "context_summary": {
      "bsonType": "string"
    },
    "message_count": {
      "bsonType": "int",
      "defaultValue": 0
    },
    "status": {
      "bsonType": "string",
      "enum": ["active", "closed"],
      "defaultValue": "active"
    },
    "created_at": {
      "bsonType": "number"
    },
    "updated_at": {
      "bsonType": "number",
      "description": "Used by get-ai-history and ask-assistant to remove conversations older than 60 days."
    }
  },
  "indexes": [
    {
      "name": "user_updated_idx",
      "key": {
        "user_id": 1,
        "updated_at": -1
      },
      "unique": false
    },
    {
      "name": "retention_updated_idx",
      "key": {
        "updated_at": 1
      },
      "unique": false
    }
  ]
}
